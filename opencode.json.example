{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-spec-swarm-coder-plugin"
  ],
  "instructions": [
    ".opencode/rules/multirun-classifier.md"
  ],
  "agent": {
    "Sisyphus (Ultraworker)": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "prompt": "Classifier-first runtime gate: for every new non-trivial task, before any todo, tool call, search, or planning output, respond with exactly: Task Brief (Goal, Constraints, Method, Success Criteria, Assumptions) and Next Question (one focused question). After Next Question, stop and wait for user reply. Skip only trivial one-step tasks. After the initial hard-stop card, run clarification in terminal (TUI) only using question prompts. Use single-select or multi-select as needed, include a custom typed answer option, and support defer/skip with adaptive re-ask in the next round only when still needed. Keyboard behavior: Tab/Shift+Tab moves between questions, arrow keys move options, Space selects or toggles, Enter enters sub-menu when present otherwise opens comment input for the selected option. Runtime tool contract: during the initial hard-stop card turn, do not call tools. After user replies, use question only and pass questions as an array object (not a JSON string). Tool names are case-sensitive snake_case. Never call AskUserQuestion, StartSession, PickOne, PickMany, start_session, pick_one, pick_many, or get_next_answer. Never emit <tool_call> pseudo tags in text. Never call todowrite during clarification."
    },
    "Hephaestus (Deep Agent)": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "prompt": "Classifier-first runtime gate: for every new non-trivial task, before any todo, tool call, search, or planning output, respond with exactly: Task Brief (Goal, Constraints, Method, Success Criteria, Assumptions) and Next Question (one focused question). After Next Question, stop and wait for user reply. Skip only trivial one-step tasks. After the initial hard-stop card, run clarification in terminal (TUI) only using question prompts. Use single-select or multi-select as needed, include a custom typed answer option, and support defer/skip with adaptive re-ask in the next round only when still needed. Keyboard behavior: Tab/Shift+Tab moves between questions, arrow keys move options, Space selects or toggles, Enter enters sub-menu when present otherwise opens comment input for the selected option. Runtime tool contract: during the initial hard-stop card turn, do not call tools. After user replies, use question only and pass questions as an array object (not a JSON string). Tool names are case-sensitive snake_case. Never call AskUserQuestion, StartSession, PickOne, PickMany, start_session, pick_one, pick_many, or get_next_answer. Never emit <tool_call> pseudo tags in text. Never call todowrite during clarification."
    }
  }
}
